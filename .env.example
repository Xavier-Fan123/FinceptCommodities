# Optional public-data key
EIA_API_KEY=

# Optional S&P Global machine-readable news API entitlement.
# The exact URLs and OAuth scope are supplied with the customer's API contract.
PLATTS_NEWS_API_URL=
PLATTS_NEWS_TOKEN_URL=
PLATTS_NEWS_CLIENT_ID=
PLATTS_NEWS_CLIENT_SECRET=
PLATTS_NEWS_SCOPE=

# Alternatively, set a short-lived bearer token instead of OAuth client fields.
PLATTS_NEWS_API_TOKEN=

# Optional one-line JSON array of additional permitted RSS/Atom sources.
# Example: [{"id":"company_feed","source":"Company","url":"https://example.com/news.xml","kind":"official_rss"}]
LPG_NEWS_FEEDS_JSON=
